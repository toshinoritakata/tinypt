<?xml version="1.0" encoding="utf-8"?>
<!-- OBJ メッシュ + transform/instance のデモ。
     地面球の上に、Y 軸 30° 回転した拡散の立方体を 2 個（均一/非均一スケール）配置し、
     上方の面光源で照らす。使い方: tinypt --scene sample/mesh.xml -o out.ppm -->
<scene version="3.0.0">
  <sensor type="perspective">
    <float name="fov" value="40"/>
    <string name="fov_axis" value="y"/>
    <transform name="to_world">
      <lookat origin="0, 1.2, 4" target="0, 0.4, 0" up="0, 1, 0"/>
    </transform>
  </sensor>

  <!-- 地面（大球） -->
  <shape type="sphere">
    <point name="center" x="0" y="-1000" z="0"/>
    <float name="radius" value="1000"/>
    <bsdf type="diffuse"><srgb name="reflectance" value="0.5, 0.5, 0.5"/></bsdf>
  </shape>

  <!-- 立方体（左）: Y 軸 30° 回転、均一スケール 0.8 -->
  <shape type="obj">
    <string name="filename" value="cube.obj"/>
    <transform name="to_world">
      <translate x="-0.9" y="0.4" z="0"/>
      <rotate x="0" y="1" z="0" angle="30"/>
      <scale value="0.8"/>
    </transform>
    <bsdf type="diffuse"><srgb name="reflectance" value="0.85, 0.35, 0.3"/></bsdf>
  </shape>

  <!-- 立方体（右）: 任意軸回転 + 非均一スケール（4x4 化した Transform でのみ表現可能） -->
  <shape type="obj">
    <string name="filename" value="cube.obj"/>
    <transform name="to_world">
      <translate x="0.9" y="0.5" z="0"/>
      <rotate x="0.3" y="1" z="0.2" angle="35"/>
      <scale x="0.6" y="1.0" z="0.6"/>
    </transform>
    <bsdf type="roughconductor">
      <string name="distribution" value="ggx"/>
      <float name="alpha" value="0.2"/>
      <srgb name="specular_reflectance" value="0.95, 0.8, 0.4"/>
    </bsdf>
  </shape>

  <!-- 発光球（上方） -->
  <shape type="sphere">
    <point name="center" x="0" y="3" z="-1"/>
    <float name="radius" value="0.8"/>
    <emitter type="area"><rgb name="radiance" value="8, 7, 5"/></emitter>
  </shape>
</scene>
