<?xml version="1.0" encoding="utf-8"?>
<!-- Cornell box（https://en.wikipedia.org/wiki/Cornell_box）。
     rectangle（壁・光源）と cube（箱）で構成。色・光源は正準値に準拠
     （白 0.725/0.71/0.68、赤 0.63/0.065/0.05、緑 0.14/0.45/0.091、
      光源は正準比 18.4:15.6:8.0 を露出込みで 4.6:3.9:2.0 にスケール）。
     箱の内部は x∈[-1,1], y∈[0,2], z∈[-1,1]。前面(z=+1)は開きカメラが覗き込む。

     推奨: tinypt --scene sample/cornell.xml --tonemap none -o cornell.ppm
     （既定の ACES は飽和色を desaturate するため Cornell box では none 推奨。
      none で白飛びしないよう光源強度を調整済み。） -->
<scene version="3.0.0">
  <integrator type="path">
    <integer name="max_depth" value="24"/>
    <integer name="rr_depth" value="5"/>
  </integrator>
  <sampler type="independent"><integer name="sample_count" value="256"/></sampler>
  <film type="hdrfilm">
    <integer name="width" value="600"/>
    <integer name="height" value="600"/>
  </film>

  <sensor type="perspective">
    <float name="fov" value="40"/>
    <string name="fov_axis" value="y"/>
    <transform name="to_world">
      <lookat origin="0, 1, 3.9" target="0, 1, 0" up="0, 1, 0"/>
    </transform>
  </sensor>

  <!-- 床（白） y=0 -->
  <shape type="rectangle">
    <transform name="to_world"><rotate x="1" angle="-90"/></transform>
    <bsdf type="diffuse"><rgb name="reflectance" value="0.725, 0.71, 0.68"/></bsdf>
  </shape>

  <!-- 天井（白） y=2 -->
  <shape type="rectangle">
    <transform name="to_world"><translate x="0" y="2" z="0"/><rotate x="1" angle="90"/></transform>
    <bsdf type="diffuse"><rgb name="reflectance" value="0.725, 0.71, 0.68"/></bsdf>
  </shape>

  <!-- 奥の壁（白） z=-1 -->
  <shape type="rectangle">
    <transform name="to_world"><translate x="0" y="1" z="-1"/></transform>
    <bsdf type="diffuse"><rgb name="reflectance" value="0.725, 0.71, 0.68"/></bsdf>
  </shape>

  <!-- 左の壁（赤） x=-1 -->
  <shape type="rectangle">
    <transform name="to_world"><translate x="-1" y="1" z="0"/><rotate y="1" angle="90"/></transform>
    <bsdf type="diffuse"><rgb name="reflectance" value="0.63, 0.065, 0.05"/></bsdf>
  </shape>

  <!-- 右の壁（緑） x=1 -->
  <shape type="rectangle">
    <transform name="to_world"><translate x="1" y="1" z="0"/><rotate y="1" angle="-90"/></transform>
    <bsdf type="diffuse"><rgb name="reflectance" value="0.14, 0.45, 0.091"/></bsdf>
  </shape>

  <!-- 背の高い箱（白）左奥 -->
  <shape type="cube">
    <transform name="to_world">
      <translate x="-0.35" y="0.6" z="-0.2"/><rotate y="1" angle="18"/><scale x="0.3" y="0.6" z="0.3"/>
    </transform>
    <bsdf type="diffuse"><rgb name="reflectance" value="0.725, 0.71, 0.68"/></bsdf>
  </shape>

  <!-- 背の低い箱（白）右手前 -->
  <shape type="cube">
    <transform name="to_world">
      <translate x="0.35" y="0.3" z="0.35"/><rotate y="1" angle="-18"/><scale value="0.3"/>
    </transform>
    <bsdf type="diffuse"><rgb name="reflectance" value="0.725, 0.71, 0.68"/></bsdf>
  </shape>

  <!-- 天井の面光源（下向き） -->
  <shape type="rectangle">
    <transform name="to_world">
      <translate x="0" y="1.98" z="0"/><rotate x="1" angle="90"/><scale x="0.35" y="0.35" z="1"/>
    </transform>
    <emitter type="area"><rgb name="radiance" value="4.6, 3.9, 2.0"/></emitter>
  </shape>

  <!-- 背景を黒に（前面の開口から手続き的な空が差し込まないように）。
       これが無いと env 未指定時のフォールバック sky() が環境光として漏れ込む。 -->
  <emitter type="constant"><rgb name="radiance" value="0, 0, 0"/></emitter>
</scene>
